# =========================================================================
# 2. Unity Workspace (unity-simulation 폴더 내부용 최신 규칙)
# =========================================================================
/unity-simulation/.utmp/
/unity-simulation/[Ll]ibrary/
/unity-simulation/[Tt]emp/
/unity-simulation/[Oo]bj/
/unity-simulation/[Bb]uild/
/unity-simulation/[Bb]uilds/
/unity-simulation/[Ll]ogs/
/unity-simulation/[Uu]ser[Ss]ettings/
/unity-simulation/*.log

# Blender & Heavy Asset Imports
/unity-simulation/*.blend1
/unity-simulation/*.blend1.meta
/unity-simulation/[Mm]emoryCaptures/
/unity-simulation/[Rr]ecordings/

# Unity Asset Store Tools & JetBrains Rider
/unity-simulation/[Aa]ssets/AssetStoreTools*
/unity-simulation/[Aa]ssets/Plugins/Editor/JetBrains*
/unity-simulation/*.DotSettings.user
/unity-simulation/Assets/[Ii]mports/
/unity-simulation/Assets/[Ii]mports.meta

# Visual Studio & Gradle Caches (Unity generated)
.vs/
.gradle/
/unity-simulation/ExportedObj/
/unity-simulation/.consulo/
/unity-simulation/*.csproj
/unity-simulation/*.unityproj
/unity-simulation/*.sln
/unity-simulation/*.slnx
/unity-simulation/*.suo
/unity-simulation/*.tmp
/unity-simulation/*.user
/unity-simulation/*.userprefs
/unity-simulation/*.pidb
/unity-simulation/*.booproj
/unity-simulation/*.svd
/unity-simulation/*.pdb
/unity-simulation/*.mdb
/unity-simulation/*.opendb
/unity-simulation/*.VC.db

# Unity3D Meta/Crash Reports
/unity-simulation/*.pidb.meta
/unity-simulation/*.pdb.meta
/unity-simulation/*.mdb.meta
/unity-simulation/sysinfo.txt
/unity-simulation/mono_crash.*

# Build Outputs (대용량 빌드 파일 방지)
/unity-simulation/*.apk
/unity-simulation/*.aab
/unity-simulation/*.unitypackage
/unity-simulation/*.unitypackage.meta
/unity-simulation/*.app

# Crashlytics & TestRunner
/unity-simulation/crashlytics-build.properties
/unity-simulation/InitTestScene*.unity*

# Addressables
/unity-simulation/ServerData
/unity-simulation/[Aa]ssets/StreamingAssets/aa*
/unity-simulation/[Aa]ssets/AddressableAssetsData/link.xml*
/unity-simulation/[Aa]ssets/Addressables_Temp*
/unity-simulation/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting & Caches
/unity-simulation/[Aa]ssets/Unity.VisualScripting.Generated/
/unity-simulation/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
/unity-simulation/[Aa]ssets/[Ss]ceneDependencyCache*

# =========================================================================
# 3. Python Workspace (python-analysis 폴더 내부 규칙)
# =========================================================================
# Python 컴파일 캐시 파일
**/__pycache__/
/python-analysis/**/*.py[cod]
/python-analysis/**/*$py.class

# 파이썬 로컬 가상환경 (Virtual Environments)
/python-analysis/.venv/
/python-analysis/venv/
/python-analysis/ENV/
/python-analysis/env/

# 주피터 노트북 임시 체크포인트 및 환경설정
/python-analysis/**/.ipynb_checkpoints/
.poetry/
.pdm/
